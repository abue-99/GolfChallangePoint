# ================================================================
# Golf ChallengePoint – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ================================================================

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
DATABASE_URL="postgresql://app:app@localhost:5432/app"

# ---------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="change-me-to-a-secure-random-string-of-at-least-32-chars"

# ---------------------------------------------------------------
# Web App (Next.js)
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------
# Backend API (NestJS)
# ---------------------------------------------------------------
# URL of the NestJS API (used by the Next.js frontend to call the API)
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Port the NestJS API listens on
API_PORT=4000

# ---------------------------------------------------------------
# Email (for password reset)
# ---------------------------------------------------------------
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
EMAIL_FROM="noreply@golfchallengepoint.com"

# ---------------------------------------------------------------
# Node environment
# ---------------------------------------------------------------
NODE_ENV="development"
