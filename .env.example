# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/challengepoint"

# JWT Secrets (replace with strong random secrets in production)
ACCESS_SECRET="your-access-token-secret-change-me"
REFRESH_SECRET="your-refresh-token-secret-change-me"

# Token Expiry
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# App
PORT=4000
NODE_ENV="development"
