// -------------------------------------------------------------------
// Generator & Datasource
// -------------------------------------------------------------------
generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL in Prisma 7 NICHT hier, sondern in prisma.config.ts konfigurieren
}

// -------------------------------------------------------------------
// Enums
// -------------------------------------------------------------------
enum Role {
  ADMIN
  COACH
  PLAYER
}

enum TaskCategory {
  APPROACH
  OTT
  ARG
  PUTTING
}

enum InputSchema {
  numeric_success
  numeric_score
  text_reflection
}

// -------------------------------------------------------------------
// Modelle
// -------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())

  // 1:1 auf PlayerProfile
  PlayerProfile PlayerProfile?

  // Coach ↔ Player Links (zwei Relationen zum selben Zielmodell → Namen nötig)
  CoachPlayerLinks  CoachPlayerLink[] @relation("CoachLinks")   // als Coach
  PlayerCoachLinks  CoachPlayerLink[] @relation("PlayerLinks")  // als Player

  // Back-Relations für CalendarEvent
  eventsAsPlayer   CalendarEvent[] @relation("CalendarEvent_Player")
  eventsAsCreator  CalendarEvent[] @relation("CalendarEvent_CreatedBy")

  // Von TaskTemplate (optional)
  templatesCreated TaskTemplate[]
}

model PlayerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CoachPlayerLink {
  id       String @id @default(cuid())
  coachId  String
  playerId String

  // Zwei Relationen zu User → unterschiedliche, sprechende Namen verwenden
  coach  User @relation("CoachLinks",  fields: [coachId],  references: [id])
  player User @relation("PlayerLinks", fields: [playerId], references: [id])

  // Verhindert doppelte Link-Paare (gleicher Coach & gleicher Player)
  @@unique([coachId, playerId])
  @@index([coachId])
  @@index([playerId])
}

model TaskTemplate {
  id          String       @id @default(cuid())
  title       String
  category    TaskCategory
  inputSchema InputSchema
  createdById String?
  createdBy   User?        @relation(fields: [createdById], references: [id])

  events      CalendarEvent[]

  @@index([createdById])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  playerId    String
  templateId  String
  start       DateTime
  end         DateTime
  createdById String

  // Zwei Relationen zu User → unterschiedliche Namen
  player     User         @relation("CalendarEvent_Player",    fields: [playerId],    references: [id])
  createdBy  User         @relation("CalendarEvent_CreatedBy", fields: [createdById], references: [id])

  template   TaskTemplate @relation(fields: [templateId], references: [id])
  TaskLogs   TaskLog[]

  @@index([playerId])
  @@index([createdById])
  @@index([templateId])
}

model TaskLog {
  id        String        @id @default(cuid())
  eventId   String
  type      InputSchema
  attempts  Int?
  successes Int?
  score     Float?
  text      String?
  createdAt DateTime      @default(now())

  event     CalendarEvent @relation(fields: [eventId], references: [id])

  @@index([eventId])
}